# Vigil SIEM: Environment Variables
# Copy this file to .env and fill in the values you need.
# Only OPENAI_API_KEY is required for full functionality; everything else has sensible defaults.

# LLM Pattern Generation (grokmoment)
# Enables automatic Grok pattern generation for unrecognized log formats.
# Without this, only lines matching existing patterns in data/patterns.json will parse.
OPENAI_API_KEY=sk-...

# SQLite Database
# Override the default database location (default: backend/api/vigil.db)
# VIGIL_DB_PATH=./vigil.db

# Email Alerts (Mailgun)
# Optional; enables email notifications for critical events.
# MAILGUN_API_KEY=key-...
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_SENDER=Vigil SIEM <alerts@mg.yourdomain.com>

# Frontend (Next.js)
# Set in frontend/.env.local, not here.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Dummy Site
# DUMMY_SITE_PORT=5000
# DUMMY_LOG_OUTPUT=dummy-site/logs/access.log
# AZURE_POSTGRES_SERVER=vigil-pg