#   Vigil SIEM: Environment Variables
# Copy this file to .env and fill in the values you need.
# Only OPENAI_API_KEY is required for full functionality; everything else has sensible defaults.


#   AI Provider
# Which LLM backend to use for the voice agent.
# Options: "openai" | "anthropic" | "groq" | "ollama"

# AI_PROVIDER=anthropic


#   LLM API Keys
# At least one key is needed for the voice agent; OpenAI is also used for auto Grok pattern generation.

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...


#   Ollama (local)
# No API key needed, just point to your running Ollama instance.

# OLLAMA_URL=http://localhost:11434


#   Text-to-Speech (ElevenLabs)
# Optional; enables spoken responses from the voice agent.

# ELEVENLABS_API_KEY=...


#   SQLite Database
# Override the default database location (default: backend/api/vigil.db)

# VIGIL_DB_PATH=./vigil.db


#   Email Alerts (Mailgun)
# Optional; enables email notifications for critical events.

# MAILGUN_API_KEY=key-...
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_SENDER=Vigil SIEM <alerts@mg.yourdomain.com>


#   Dummy Site

# DUMMY_SITE_PORT=5000
# DUMMY_LOG_OUTPUT=dummy-site/logs/access.log