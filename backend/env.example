#   Vigil SIEM: Backend Environment Variables
# Copy this file to .env.local and fill in only what you need.
# This file is for the Vigil backend/frontend stack itself.
# Website-side variables such as VIGIL_API_URL belong on the monitored website,
# not in this backend env file.


#   RECOMMENDED: Backend URL (Frontend → Backend connection)
# Set this when the backend runs on a different host from the frontend.
# The frontend's route handler proxy and WebSocket rewrite both use this.
# Default: http://127.0.0.1:8000 (local development)

# VIGIL_BACKEND_URL=http://127.0.0.1:8000


#   OPTIONAL: Voice Agent & Auto Pattern Generation
# At least one LLM key is needed for the voice agent.
# OPENAI_API_KEY is also used for automatic Grok pattern generation.

# OPENAI_API_KEY=sk-...


#   OPTIONAL: Alternate AI Provider
# Switch the voice agent to a different LLM backend.
# Options: "openai" (default) | "anthropic" | "groq" | "ollama"

# AI_PROVIDER=anthropic

# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...

# Ollama (local): no API key needed, just a running instance.
# OLLAMA_URL=http://localhost:11434


#   OPTIONAL: Text-to-Speech (ElevenLabs)
# Enables spoken responses from the voice agent.

# ELEVENLABS_API_KEY=...


#   OPTIONAL: Email Alerts (Mailgun)
# Sends email notifications when critical events are detected.

# MAILGUN_API_KEY=key-...
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_SENDER=Vigil SIEM <alerts@mg.yourdomain.com>


#   OPTIONAL: Browser CORS allowlist
# Only needed if browser code from another origin will call Vigil directly.
# Server-to-server ingestion does not need this.
# localhost:3000 is always allowed by default.

# VIGIL_CORS_ORIGINS=https://your-site.vercel.app,https://another-site.com


#   OPTIONAL: Custom Paths
# Override default file locations. Sensible defaults are used if unset.

# VIGIL_DB_PATH=./vigil.db                         # Default: backend/api/vigil.db
# VIGIL_LOG_PATH=/var/log/access.log               # Alternative to CLI arg for collector


#   OPTIONAL: Dummy Site (development only)
# DUMMY_SITE_PORT=5000
# DUMMY_LOG_OUTPUT=dummy-site/logs/access.log